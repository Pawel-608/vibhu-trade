# Phoenix perps HTTP/WS API base URL.
NEXT_PUBLIC_PHOENIX_API_URL=https://perp-api.phoenix.trade

# Solana RPC endpoint (HTTP). Used by the Rise SDK and tx submission.
# In production this should point at the in-app /api/rpc proxy that hides a
# paid RPC key — see PLAN.md §3. Leave blank to use the SDK default.
NEXT_PUBLIC_SOLANA_RPC_URL=

# Privy app ID — enables the "Continue with social login" path. Create your
# OWN Privy app at dashboard.privy.io (Solana enabled, embedded wallets on).
# The app authenticates the embedded wallet to Phoenix via wallet-signature,
# so any Privy app works. Leave blank to run external-wallet connect only.
NEXT_PUBLIC_PRIVY_APP_ID=

# Referral code applied when activating a new account's invite
# (src/auth/OnboardingFlow.tsx). Accounts created through this app are credited
# to this referral. Defaults to GZNNNBK5 when unset.
NEXT_PUBLIC_PHOENIX_REFERRAL_CODE=GZNNNBK5
