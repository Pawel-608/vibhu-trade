# Phoenix perps HTTP/WS API base URL.
NEXT_PUBLIC_PHOENIX_API_URL=https://perp-api.phoenix.trade

# Server-side Solana RPC endpoint — the upstream the /api/rpc proxy forwards
# to. Set this to your Solana Vibe Station RPC URL (api_key in the querystring).
# Server-only — never exposed to the browser; in production set it as a RUNTIME
# variable on the Worker (Variables and Secrets), not a build-time variable.
SOLANA_RPC_URL=

# Public Solana RPC endpoint (HTTP), exposed to the browser. Point this at the
# in-app /api/rpc proxy so the Solana Vibe Station key stays server-side — see
# PLAN.md §3. Leave blank to use the SDK default.
NEXT_PUBLIC_SOLANA_RPC_URL=

# Privy app ID — enables the "Sign in" path. Create your OWN Privy app at
# dashboard.privy.io (Solana enabled, embedded wallets on). The app
# authenticates the embedded wallet to Phoenix via wallet-signature, so any
# Privy app works. Leave blank to disable login.
NEXT_PUBLIC_PRIVY_APP_ID=

# Referral code applied when activating a new account's invite
# (src/auth/OnboardingFlow.tsx). Accounts created through this app are credited
# to this referral. Defaults to GZNNNBK5 when unset.
NEXT_PUBLIC_PHOENIX_REFERRAL_CODE=GZNNNBK5

# --- Flight builder routing (earn builder fees) -----------------------------
# Public key of the dedicated builder wallet you registered with Phoenix's
# Flight program via the one-time scripts/register-flight-builder.ts (see
# scripts/FLIGHT-RUNBOOK.md). When set, in-app limit + market orders route
# through the Flight program and builder fees accrue to that builder's trader
# account. Leave blank to place native orders that earn no builder fee.
NEXT_PUBLIC_FLIGHT_BUILDER_AUTHORITY=

# Builder trader-account indices used to derive the fee-collector trader PDA.
# These MUST match the values passed at registration. Both default to 0 —
# leave blank unless you registered with non-zero indices.
NEXT_PUBLIC_FLIGHT_BUILDER_PDA_INDEX=
NEXT_PUBLIC_FLIGHT_BUILDER_SUBACCOUNT_INDEX=
